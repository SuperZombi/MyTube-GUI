{
	"manifest_version": 3,
	"version": "1.0.1",
	"name": "MyTube Companion",
	"description": "Share what you like with your friends.",
	"icons": {
		"128": "icon-128.png"
	},
	"host_permissions": [
		"https://www.youtube.com/*",
		"https://music.youtube.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://www.youtube.com/*",
				"https://music.youtube.com/*"
			],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	]
}
